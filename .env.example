# .env.example (copy to .env and fill)
AETHERGRAPH_WORKSPACE=./aethergraph_workspace

# Slack (optional)
AETHERGRAPH_SLACK__ENABLED=false            # set to true to enable
AETHERGRAPH_SLACK__BOT_TOKEN=               # your bot token
AETHERGRAPH_SLACK__APP_TOKEN=               # your app token
AETHERGRAPH_SLACK__SIGNING_SECRET=          # your signing secret
AETHERGRAPH_SLACK__SOCKET_MODE_ENABLED=true # usually true for local testing
AETHERGRAPH_SLACK__WEBHOOK_ENABLED=false    # usually false for local testing

# Telegram (optional)
AETHERGRAPH_TELEGRAM__ENABLED=false         # set to true to enable
AETHERGRAPH_TELEGRAM__BOT_TOKEN=            # your bot token
AETHERGRAPH_TELEGRAM__POLLING_ENABLED=true  # usually true for local testing
AETHERGRAPH_TELEGRAM__WEBHOOK_ENABLED=false # usually false for local testing


# LLM Settings
AETHERGRAPH_LLM__ENABLED=true
AETHERGRAPH_LLM__DEFAULT__PROVIDER=openai   # e.g., openai, anthropic, google, deepseek, lmstudio, etc.
AETHERGRAPH_LLM__DEFAULT__MODEL=            # e.g., gpt-4o-mini, claude-2, gemini-2.5-flash-lite, qwen/qwen2.5-vl-7b, etc.
AETHERGRAPH_LLM__DEFAULT__EMBED_MODEL=      # e.g., text-embedding-3-small, text-embedding-004, etc. Optional if your use case needs embeddings.
AETHERGRAPH_LLM__DEFAULT__REASONING_EFFORT= # e.g., low, medium, high, xhigh, max
AETHERGRAPH_LLM__DEFAULT__THINKING_MODE=    # e.g., auto, on, off
AETHERGRAPH_LLM__DEFAULT__COMPATIBILITY_POLICY=compat  # compat or strict
AETHERGRAPH_LLM__DEFAULT__API_KEY=          # your API key 


# Optional LLM Settings: register as context.llm("my_profile"); replace MY_PROFILE with your profile name
# You can also set up multiple profiles in your code.
# AETHERGRAPH_LLM__PROFILES__MY_PROFILE__PROVIDER=google
# AETHERGRAPH_LLM__PROFILES__MY_PROFILE__MODEL=
# AETHERGRAPH_LLM__PROFILES__MY_PROFILE__EMBED_MODEL=
# AETHERGRAPH_LLM__PROFILES__MY_PROFILE__REASONING_EFFORT=high
# AETHERGRAPH_LLM__PROFILES__MY_PROFILE__THINKING_MODE=auto
# AETHERGRAPH_LLM__PROFILES__MY_PROFILE__COMPATIBILITY_POLICY=compat
# AETHERGRAPH_LLM__PROFILES__MY_PROFILE__API_KEY=

# RAG Settings [Optional]
AETHERGRAPH_RAG__BACKEND=sqlite              # e.g., faiss and sqlite, etc. (faiss needs extra dependencies)
AETHERGRAPH_RAG__DIM=1536                   # e.g., 1536 for text embeddings
